# ===========================================
# Webhook 配置
# ===========================================
# Webhook 访问路径（不要以 / 开头）
# 例如: webhook/secure-a812c2e1-4b1d-9813-ab113-ef489
# 完整访问地址为: http://your-server:5000/webhook/secure-a812c2e1-4b1d-9813-ab113-ef489
WEBHOOK_PATH=webhook/secure-a812c2e1
ADMIN_SECRET=
# ===========================================
# qBittorrent 标准模式配置
# ===========================================
# 多个服务器用逗号分隔
QB_SERVERS=
QB_USERNAME=heshui
QB_PASSWORD=1wuhongli

# ===========================================
# Vertex 代理模式配置（可选）
# ===========================================
# 如果设置了 VTCOOKIES 和 VTURL，将自动启用 VT 代理模式
# VT 模式会覆盖标准 qBittorrent 配置

# VT Cookies（留空则使用标准模式；若配置了下方登录凭证则会自动刷新，此项作为首次冷启动兜底）
VTCOOKIES=

# VT 服务器地址 ip:3000(你的端口或者域名)
VTURL=

# ── Vertex 自动登录刷新配置（可选，配置后 Cookie 失效时自动重新登录，无需手动替换）──
# 登录用户名
VT_USERNAME=admin
# 登录密码（MD5，与接口 payload 的 password 字段格式一致）f12在登录页面看login api 或者 直接用你的密码原文md5
VT_PASSWORD_MD5=
# Cookie 有效性探测最小间隔（秒），避免频繁请求，默认 300s = 5分钟
VT_COOKIE_CHECK_INTERVAL=300

# VT 代理 ID 列表（用逗号分隔，只需填写代理 ID）
# 系统会自动生成完整的代理 URL: {VTURL}/proxy/client/{proxy_id}
# 例如: 1043dd9e 会自动转换为 http://域名/proxy/client/1043dd9e
VT_PROXIES=d85456e1,1043dd9e,cc7c3444,e8217f20,2665a088,dc932f64

# ===========================================
# 服务器选择策略
# ===========================================
# 可选值:
# - upload_speed    : 选择上传速度最低的服务器（推荐）
# - torrent_count   : 选择种子数最少的服务器
# - free_space      : 选择剩余空间最大的服务器
# - free_space 
SELECT_STRATEGY=torrent_count
FETCH_TIMEOUT=2

# ===========================================
# 重试配置
# ===========================================
# 最大重试次数（推送失败后尝试次数）
MAX_RETRIES=3

# 重试间隔（秒）
RETRY_DELAY=5

# ===========================================
# Telegram 通知配置（可选）
# ===========================================
# Telegram Bot Token（从 @BotFather 获取）
TG_BOT_TOKEN=

# Telegram Chat ID（你的用户 ID 或群组 ID）
TG_CHAT_ID=

# ===========================================
# 其他配置
# ===========================================
# Flask 运行端口
FLASK_PORT=5000

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO